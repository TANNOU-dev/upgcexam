# Copier vers .env et adapter en production
DJANGO_SECRET_KEY=changez-moi-en-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=votredomaine.com,www.votredomaine.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://votredomaine.com,https://www.votredomaine.com

# Sécurité HTTPS : mettre "true" uniquement en production derrière un proxy TLS
DJANGO_SECURE_SSL=false

# PostgreSQL (laisser POSTGRES_DB vide pour utiliser SQLite en développement)
POSTGRES_DB=upgcexam
POSTGRES_USER=upgcexam
POSTGRES_PASSWORD=changez-moi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (cache partagé + Channels en production)
REDIS_URL=redis://localhost:6379/0

# Fichier de log local optionnel ; en conteneur, conserver false et lire stdout
DJANGO_LOG_TO_FILE=false

# Email SMTP (production)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@votredomaine.com
DJANGO_EMAIL_HOST=smtp.votredomaine.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true

# VAPID — Notifications push (générer avec : python -c "from pywebpush import generate_vapid_keys; import json; print(json.dumps(generate_vapid_keys()))" )
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Google OAuth (optionnel — pour la connexion via Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
